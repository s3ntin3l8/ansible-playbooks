# ==============================================================================
# Ansible Environment Configuration
# ==============================================================================
# Copy this file to .env and replace the placeholder values with your actual
# environment details. The .env file is ignored by git.
# ==============================================================================

# ------------------------------------------------------------------------------
# Proxmox Configuration
# ------------------------------------------------------------------------------
# URL to the Proxmox API (e.g., https://192.168.1.100:8006)
PROXMOX_URL=https://192.168.1.100:8006
PROXMOX_HOST_IP=192.168.1.100

# Proxmox API user and token ID for authentication
PROXMOX_USER=ansible@pam
PROXMOX_TOKEN_ID=ansible

# ------------------------------------------------------------------------------
# Static Inventory IPs
# ------------------------------------------------------------------------------
TAILSCALE_ROUTER_IP=192.168.1.101
DEV_01_IP=192.168.1.102
OPENCLAW_01_IP=192.168.1.103
PIHOLE_LXC_IP=192.168.1.104
PIHOLE_ZERO_IP=192.168.1.105

# ------------------------------------------------------------------------------
# Networking
# ------------------------------------------------------------------------------
# Subnet used for Tailscale routing
TAILSCALE_SUBNET=192.168.1.0/24

# Base domain for Traefik proxy
TRAEFIK_DOMAIN=local.yourdomain.com

# ------------------------------------------------------------------------------
# Identity & Access
# ------------------------------------------------------------------------------
# GitHub username to fetch SSH keys for the primary user
GITHUB_USERNAME=your_username

# Primary public key for the 'ansible' automation user
ANSIBLE_SSH_PUBKEY=ssh-ed25519 AAAAC3NzaC1... ansible

# Primary public key for the personal user
BJOERN_SSH_PUBKEY=ssh-ed25519 AAAAC3NzaC1... bjoern

# ------------------------------------------------------------------------------
# Application Secrets
# ------------------------------------------------------------------------------
# Default admin password for Pi-hole
PIHOLE_ADMIN_PASSWORD=changeme
